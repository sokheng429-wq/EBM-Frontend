# Base URL of the Spring Boot backend's API.
#
# Local dev:  copy this file to `.env` and keep the localhost URL.
# Production: `.env.production` already sets the Render backend URL, so
#             Cloudflare Pages builds pick it up automatically. You do NOT
#             need to set VITE_API_URL in the Cloudflare dashboard.
VITE_API_URL=http://localhost:8081/api