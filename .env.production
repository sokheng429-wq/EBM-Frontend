# Production build environment for Cloudflare Pages.
# Vite picks this up automatically during `npm run build` and bakes the
# value into the bundle. No secrets here - the API URL is public.
#
# Cloudflare Pages build settings:
#   Build command:      npm run build
#   Output directory:    dist
#   (No env vars needed in the CF dashboard - this file handles it.)
VITE_API_URL=https://ebm-backend.onrender.com/api

# https://ebm-backend.onrender.com/api